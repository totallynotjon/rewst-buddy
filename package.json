				{
					"command": "rewst-buddy.CopyPath",
					"when": "viewItem == bundleTemplate",
					"group": "5_copypath@1"
				},
				{
					"command": "rewst-buddy.CopyRelativePath",
					"when": "viewItem == bundleTemplate",
					"group": "5_copypath@2"
				},
				{
					"command": "rewst-buddy.RevealInExplorer",
					"when": "viewItem == bundleTemplate",
					"group": "5_copypath@3"
				},
				{
					"command": "rewst-buddy.CopyTemplateID",
					"when": "viewItem == bundleTemplate",
					"group": "z_rewst@1"
				},
				{
					"command": "rewst-buddy.OpenInRewst",
					"when": "viewItem == bundleTemplate",
					"group": "z_rewst@2"
				},
				{
					"command": "rewst-buddy.DiffAgainstRewst",
					"when": "viewItem == bundleTemplate && rewst-buddy.anyActiveSessions",
					"group": "z_rewst@3"
				},
				{
					"command": "rewst-buddy.SyncTemplate",
					"when": "viewItem == bundleTemplate && rewst-buddy.anyActiveSessions",
					"group": "z_rewst@4"
				},
				{
					"command": "rewst-buddy.UnlinkTemplate",
					"when": "viewItem == bundleTemplate",
					"group": "z_rewst@5"
				},
				{
					"command": "rewst-buddy.DeleteTemplate",
					"when": "viewItem == bundleTemplate && rewst-buddy.anyActiveSessions",
					"group": "z_rewst@6"
				},
				{
					"command": "rewst-buddy.RemoveSession",
					"when": "viewItem == session",
					"group": "z_rewst@1"
				}
			],
			"editor/context": [
				{
					"command": "rewst-buddy.CopyTemplateID",
					"group": "z_rewst",
					"when": "resourcePath in rewst-buddy.linkedTemplates"
				},
				{
					"command": "rewst-buddy.OpenInRewst",
					"group": "z_rewst",
					"when": "resourcePath in rewst-buddy.linkedTemplates"
				},
				{
					"command": "rewst-buddy.DiffAgainstRewst",
					"group": "z_rewst",
					"when": "rewst-buddy.anyActiveSessions && resourcePath in rewst-buddy.linkedTemplates"
				},
				{
					"command": "rewst-buddy.PreviewJinjaRender",
					"group": "z_rewst",
					"when": "rewst-buddy.anyActiveSessions && resourcePath in rewst-buddy.linkedTemplates"
				},
				{
					"command": "rewst-buddy.SyncTemplate",
					"group": "z_rewst",
					"when": "rewst-buddy.anyActiveSessions && resourcePath in rewst-buddy.linkedTemplates"
				},
				{
					"command": "rewst-buddy.LinkTemplateInteractive",
					"group": "z_rewst",
					"when": "rewst-buddy.anyActiveSessions && resourcePath not in rewst-buddy.linkedTemplates"
				},
				{
					"command": "rewst-buddy.CreateTemplate",
					"group": "z_rewst",
					"when": "rewst-buddy.anyActiveSessions && resourcePath not in rewst-buddy.linkedTemplates"
				},
				{
					"command": "rewst-buddy.UnlinkTemplate",
					"group": "z_rewst",
					"when": "resourcePath in rewst-buddy.linkedTemplates"
				},
				{
					"command": "rewst-buddy.DeleteTemplate",
					"group": "z_rewst",
					"when": "rewst-buddy.anyActiveSessions && resourcePath in rewst-buddy.linkedTemplates"
				}
			],
			"editor/title": [
				{
					"command": "rewst-buddy.PreviewJinjaRender",
					"group": "navigation",
					"when": "rewst-buddy.anyActiveSessions && resourcePath in rewst-buddy.linkedTemplates"
				},
				{
					"command": "rewst-buddy.KeepLocalConflict",
					"group": "navigation@1",
					"when": "rewst-buddy.conflictDiffActive"
				},
				{
					"command": "rewst-buddy.TakeRemoteConflict",
					"group": "navigation@2",
					"when": "rewst-buddy.conflictDiffActive"
				}
			]
		}
	},
	"scripts": {
		"prepare": "husky",
		"format:pretty": "prettier --write \"./**/*.{js,jsx,mjs,cjs,ts,tsx,json,md}\"",
		"format:eslint": "eslint --fix src",
		"format": "npm-run-all -p format:*",
		"lint": "eslint src",
		"type-check": "tsc --noEmit",
		"codegen": "graphql-codegen --config src/codegen.ts",
		"codegen:refresh-schema": "graphql-codegen --config src/codegen.schema.ts",
		"codegen:check": "npm run codegen && git diff --exit-code src/sessions/graphql/generated/ || (echo 'Generated GraphQL output is out of sync! Run: npm run codegen' && exit 1)",
		"lint:staged": "lint-staged",
		"pre-commit": "bash .husky/pre-commit",
		"check-types": "tsc --noEmit --watch",
		"test": "npm run compile:test && vitest run && vscode-test --label unit && vscode-test --label integration",
		"test:unit": "npm run compile:test && vitest run && vscode-test --label unit",
		"test:vitest": "vitest run",
		"test:integration": "npm run compile:test && vscode-test --label integration",
		"test:grep": "node scripts/test-grep.mjs",
		"test:grep:integration": "npm run compile:test && vscode-test --label grep-integration --grep",
		"compile:test": "node esbuild.mjs",
		"build": "npm run package",
		"dev": "npm run watch",
		"watch": "npm-run-all -p watch:*",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"watch:esbuild": "node esbuild.mjs --watch",
		"compile": "node esbuild.mjs",
		"vscode:prepublish": "npm run package",
		"package": "node esbuild.mjs --production",
		"changelog:new": "node scripts/changelog/new.mjs",
		"changelog:check": "node scripts/changelog/check.mjs",
		"changelog:build": "node scripts/changelog/build.mjs",
		"test:changelog": "npm run test:changelog:tools && npm run test:changelog:ci",
		"test:changelog:tools": "node --test scripts/changelog/*.test.mjs",
		"test:changelog:ci": "node scripts/changelog/check.mjs --base main --include-working-tree",
		"release:tag": "git tag v$npm_package_version && git push origin v$npm_package_version"
	},
	"devDependencies": {
		"@0no-co/graphqlsp": "^1.15.2",
		"@eslint/js": "^9.39.2",
		"@graphql-codegen/cli": "^6.1.0",
		"@graphql-codegen/client-preset": "^5.2.1",
		"@graphql-codegen/schema-ast": "^5.0.0",
		"@graphql-codegen/typescript": "^5.0.6",
		"@graphql-codegen/typescript-operations": "^5.0.6",
		"@parcel/watcher": "^2.5.1",
		"@stylistic/eslint-plugin": "^5.6.1",
		"@types/glob": "^8.1.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "^25.0.3",
		"@types/vscode": "^1.120.0",
		"@types/ws": "^8.18.1",
		"@typescript-eslint/eslint-plugin": "^8.50.0",
		"@typescript-eslint/parser": "^8.50.0",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.5.2",
		"cross-env": "^10.1.0",
		"esbuild": "^0.28.1",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import": "^2.32.0",
		"glob": "^13.0.0",
		"globals": "^16.5.0",
		"graphql": "^16.12.0",
		"graphql-request": "^7.4.0",
		"graphql-ws": "^6.0.6",
		"husky": "^9.1.7",
		"lint-staged": "^15.5.2",
		"markdownlint-cli2": "^0.22.1",
		"npm-run-all": "^4.1.5",
		"prettier": "^3.7.4",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.50.0",
		"url-pattern": "^1.0.3",
		"uuid": "^13.0.0",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.1.9",
		"ws": "^8.18.3"
	},
	"lint-staged": {
		"src/sessions/graphql/generated/**": [],
		"*.{ts,js,mjs,cjs}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.json": [
			"prettier --write"
		],
		"*.md": [
			"prettier --write",
			"markdownlint-cli2 --fix"
		]
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"zod": "^4.4.3"
	}
}
