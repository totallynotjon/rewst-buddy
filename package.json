{
	"publisher": "JBramley",
	"name": "rewst-buddy",
	"displayName": "rewst-buddy",
	"description": "Unofficial community VS Code extension for editing Rewst templates locally. Not affiliated with Rewst LLC.",
	"version": "0.44.1",
	"icon": "media/rewst-buddy.png",
	"engines": {
		"vscode": "^1.122.0"
	},
	"categories": [
		"Other"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/totallynotjon/rewst-buddy.git"
	},
	"bugs": {
		"url": "https://github.com/totallynotjon/rewst-buddy/issues"
	},
	"license": "MIT",
	"homepage": "https://github.com/totallynotjon/rewst-buddy/blob/main/README.md",
	"keywords": [
		"rewst",
		"Rewst",
		"buddy"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"languageModelChatProviders": [
			{
				"vendor": "rewst-buddy",
				"displayName": "Cage-Free Rewsty"
			}
		],
		"mcpServerDefinitionProviders": [
			{
				"id": "rewst-buddy.mcpServer",
				"label": "Rewst Buddy"
			}
		],
		"configuration": {
			"title": "Settings Editor Rewst-Buddy",
			"type": "object",
			"properties": {
				"rewst-buddy.regions": {
					"type": "array",
					"default": [
						{
							"name": "North America",
							"cookieName": "appSession",
							"graphqlUrl": "https://api.rewst.io/graphql",
							"loginUrl": "https://app.rewst.io"
						}
					],
					"description": "Regional configuration for different Rewst instances",
					"items": {
						"type": "object",
						"properties": {
							"name": {
								"type": "string",
								"description": "Display name for the region"
							},
							"cookieName": {
								"type": "string",
								"description": "Session cookie name for authentication"
							},
							"graphqlUrl": {
								"type": "string",
								"description": "GraphQL API endpoint URL"
							},
							"loginUrl": {
								"type": "string",
								"description": "Login page URL for the region"
							},
							"subscriptionsUrl": {
								"type": "string",
								"description": "GraphQL subscriptions WebSocket URL (optional; derived from graphqlUrl when omitted)"
							}
						},
						"required": [
							"name",
							"cookieName",
							"graphqlUrl",
							"loginUrl"
						]
					}
				},
				"rewst-buddy.syncOnSaveByDefault": {
					"type": "boolean",
					"default": false,
					"description": "When enabled, all linked files sync on save by default (use Disable Sync-On-Save to exclude specific files). When disabled, files only sync when explicitly enabled."
				},
				"rewst-buddy.autoFetchOnOpen": {
					"type": "boolean",
					"default": true,
					"description": "When enabled, automatically fetch remote template updates when opening linked files. This only applies changes if the local file hasn't been modified since the last sync."
				},
				"rewst-buddy.server.enabled": {
					"type": "boolean",
					"default": true,
					"description": "Enable the local HTTP server to receive session tokens from browser extensions"
				},
				"rewst-buddy.server.port": {
					"type": "number",
					"default": 27121,
					"minimum": 1024,
					"maximum": 65535,
					"description": "Port number for the local HTTP server (default: 27121)"
				},
				"rewst-buddy.server.host": {
					"type": "string",
					"default": "127.0.0.1",
					"description": "Host address to bind the server (default: 127.0.0.1 for localhost-only access)"
				},
				"rewst-buddy.ai.conversationType": {
					"type": "string",
					"enum": [
						"HELP_DOCS",
						"WORKFLOW_DIAGNOSIS"
					],
					"default": "HELP_DOCS",
					"description": "Conversation type sent to the Rewst AI assistant (HELP_DOCS answers documentation questions)"
				},
				"rewst-buddy.ai.customInstructions": {
					"type": "string",
					"default": "",
					"editPresentation": "multilineText",
					"description": "Standing instructions prepended to every message sent to the Rewst AI assistant (e.g. preferred answer style, your environment details). Note: this is sent as part of your message — it cannot override Rewst's own system prompt."
				},
				"rewst-buddy.ai.showActivity": {
					"type": "boolean",
					"default": true,
					"description": "Show Cage-Free Rewsty's live activity (documentation searches and tool calls) as it works, instead of only a spinner until the answer arrives."
				},
				"rewst-buddy.ai.maxBuddyToolRounds": {
					"type": "number",
					"default": 8,
					"minimum": 1,
					"maximum": 100,
					"description": "Maximum in-process Buddy tool calls Cage-Free Rewsty may run within one chat response before stopping and asking you to continue."
				},
				"rewst-buddy.mcp.enable": {
					"type": "boolean",
					"default": false,
					"description": "Expose your authenticated Rewst sessions to external MCP clients (Claude Desktop, Claude Code, Cursor) through a local, credential-free bridge. Off by default: enabling it lets an external agent read your Rewst data through your session. This is an unofficial extension — review the security notes before enabling."
				},
				"rewst-buddy.mcp.enableWriteTools": {
					"type": "boolean",
					"default": false,
					"description": "Allow workflow MCP tools that change Rewst data (buddy_workflow_edit, buddy_workflow_autolayout, and buddy_workflow_run). Even when enabled, each change still requires your approval inside VS Code. Workflow edits do not expose task parallelism controls (new tasks use sequential graph defaults). Does not expose raw GraphQL mutation."
				},
				"rewst-buddy.mcp.enableDangerousGraphqlMutation": {
					"type": "boolean",
					"default": false,
					"description": "Allow the raw buddy_graphql_mutate MCP tool to run arbitrary GraphQL mutations against the live Rewst organization. This is separate from write tools because it can change anything your Rewst session can change; each mutation still requires per-resource approval inside VS Code."
				},
				"rewst-buddy.mcp.alwaysAllowedOrgs": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "Organization ids that are always in the working scope, regardless of what you pin with Set Working Scope. Tools may always operate on these orgs (e.g. a sandbox you never want to re-pin). The working scope and this list together form the effective allowed set: a write must target an org in that set, so with nothing pinned and this list empty, writes are blocked. Find org ids with the buddy_list_orgs tool. (Replaces the former writeOrgAllowlist; old values are still read.)"
				},
				"rewst-buddy.mcp.workingOrgScope": {
					"type": "string",
					"enum": [
						"strict",
						"writes"
					],
					"default": "strict",
					"enumDescriptions": [
						"Once a working org is pinned, reads and writes are both limited to the working scope.",
						"Only writes are limited to the working scope; reads may target any org your sessions manage."
					],
					"description": "How the working scope constrains reads. 'strict' (default) scopes reads to the working orgs once one is pinned; 'writes' leaves reads cross-org and only gates writes."
				}
			}
		},
