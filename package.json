			}
		],
		"submenus": [],
		"menus": {
			"explorer/context": [
				{
					"command": "rewst-buddy.LinkFolder",
					"when": "rewst-buddy.anyActiveSessions && explorerResourceIsFolder && resourcePath not in rewst-buddy.linkedFolders"
				},
				{
					"command": "rewst-buddy.UnlinkFolder",
					"when": "explorerResourceIsFolder && resourcePath in rewst-buddy.linkedFolders"
				},
				{
					"command": "rewst-buddy.FetchFolder",
					"when": "rewst-buddy.anyActiveSessions && explorerResourceIsFolder && resourcePath in rewst-buddy.linkedFolders"
				},
				{
					"command": "rewst-buddy.CopyTemplateID",
					"when": "!explorerResourceIsFolder && resourcePath in rewst-buddy.linkedTemplates"
				},
				{
					"command": "rewst-buddy.OpenInRewst",
					"when": "!explorerResourceIsFolder && resourcePath in rewst-buddy.linkedTemplates"
				}
			],
