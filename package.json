			"view/title": [
				{
					"command": "rewst-buddy.BundleTemplates",
					"when": "view == rewst-buddy.bundleTree",
					"group": "navigation"
				}
			],
			"view/item/context": [
				{
					"command": "rewst-buddy.OpenToTheSide",
					"when": "viewItem == bundleTemplate",
					"group": "navigation@1"
				},
				{
					"command": "rewst-buddy.RevealInOS",
					"when": "viewItem == bundleTemplate",
					"group": "navigation@3"
				},
				{
					"command": "rewst-buddy.OpenInIntegratedTerminal",
					"when": "viewItem == bundleTemplate",
					"group": "navigation@4"
				},
				{
					"command": "rewst-buddy.CopyPath",
					"when": "viewItem == bundleTemplate",
					"group": "5_copypath@1"
				},
				{
					"command": "rewst-buddy.CopyRelativePath",
					"when": "viewItem == bundleTemplate",
					"group": "5_copypath@2"
				},
				{
					"command": "rewst-buddy.RevealInExplorer",
					"when": "viewItem == bundleTemplate",
					"group": "5_copypath@3"
				},
				{
					"command": "rewst-buddy.CopyTemplateID",
					"when": "viewItem == bundleTemplate",
					"group": "z_rewst@1"
				},
				{
					"command": "rewst-buddy.OpenInRewst",
					"when": "viewItem == bundleTemplate",
					"group": "z_rewst@2"
				},
				{
					"command": "rewst-buddy.SyncTemplate",
					"when": "viewItem == bundleTemplate && rewst-buddy.anyActiveSessions",
					"group": "z_rewst@3"
				},
				{
					"command": "rewst-buddy.UnlinkTemplate",
					"when": "viewItem == bundleTemplate",
					"group": "z_rewst@4"
				},
				{
					"command": "rewst-buddy.DeleteTemplate",
					"when": "viewItem == bundleTemplate && rewst-buddy.anyActiveSessions",
					"group": "z_rewst@5"
				}
			],
			"editor/context": [
				{
					"command": "rewst-buddy.CopyTemplateID",
					"group": "z_rewst",
					"when": "resourcePath in rewst-buddy.linkedTemplates"
				},
				{
					"command": "rewst-buddy.OpenInRewst",
					"group": "z_rewst",
					"when": "resourcePath in rewst-buddy.linkedTemplates"
				},
				{
					"command": "rewst-buddy.SyncTemplate",
					"group": "z_rewst",
					"when": "rewst-buddy.anyActiveSessions && resourcePath in rewst-buddy.linkedTemplates"
				},
				{
					"command": "rewst-buddy.LinkTemplateInteractive",
					"group": "z_rewst",
					"when": "rewst-buddy.anyActiveSessions && resourcePath not in rewst-buddy.linkedTemplates"
				},
				{
					"command": "rewst-buddy.CreateTemplate",
					"group": "z_rewst",
					"when": "rewst-buddy.anyActiveSessions && resourcePath not in rewst-buddy.linkedTemplates"
				},
				{
					"command": "rewst-buddy.UnlinkTemplate",
					"group": "z_rewst",
					"when": "resourcePath in rewst-buddy.linkedTemplates"
				},
				{
					"command": "rewst-buddy.DeleteTemplate",
					"group": "z_rewst",
					"when": "rewst-buddy.anyActiveSessions && resourcePath in rewst-buddy.linkedTemplates"
				}
			]
		}
	},
	"scripts": {
		"prepare": "husky",
		"format:pretty": "prettier --write \"./**/*.{js,jsx,mjs,cjs,ts,tsx,json,md}\"",
		"format:eslint": "eslint --fix src",
		"format": "npm-run-all -p format:*",
		"lint": "eslint src",
		"type-check": "tsc --noEmit",
		"codegen": "graphql-codegen --config src/codegen.ts",
		"codegen:check": "npm run codegen && git diff --exit-code src/sessions/graphql/sdk.ts || (echo 'SDK is out of sync! Run: npm run codegen' && exit 1)",
		"lint:staged": "lint-staged",
		"pre-commit": "bash .husky/pre-commit",
		"check-types": "tsc --noEmit --watch",
		"test": "npm run compile:test && vscode-test",
		"test:unit": "npm run compile:test && vscode-test --grep 'Unit:'",
		"test:integration": "npm run compile:test && vscode-test --grep 'Integration:'",
		"test:grep": "npm run compile:test && vscode-test --grep",
		"test:grep:integration": "npm run compile:test && cross-env REWST_TEST_INTEGRATION=1 vscode-test --grep",
		"compile:test": "webpack --mode development",
		"build": "npm run package",
		"dev": "npm run watch",
		"watch": "npm-run-all -p watch:*",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"watch:webpack": "webpack --mode development --watch",
		"compile": "webpack --mode development",
		"vscode:prepublish": "npm run package",
		"package": "webpack --mode production --devtool hidden-source-map"
	},
	"devDependencies": {
		"@0no-co/graphqlsp": "^1.15.2",
		"@eslint/js": "^9.39.2",
		"@graphql-codegen/cli": "^6.1.0",
		"@graphql-codegen/client-preset": "^5.2.1",
		"@graphql-codegen/schema-ast": "^5.0.0",
		"@graphql-codegen/typescript": "^5.0.6",
		"@graphql-codegen/typescript-graphql-request": "^6.3.0",
		"@graphql-codegen/typescript-operations": "^5.0.6",
		"@parcel/watcher": "^2.5.1",
		"@stylistic/eslint-plugin": "^5.6.1",
		"@types/glob": "^8.1.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "^25.0.3",
		"@types/vscode": "^1.120.0",
		"@types/ws": "^8.18.1",
		"@typescript-eslint/eslint-plugin": "^8.50.0",
		"@typescript-eslint/parser": "^8.50.0",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.5.2",
		"cross-env": "^10.1.0",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import": "^2.32.0",
		"glob": "^13.0.0",
		"globals": "^16.5.0",
		"graphql": "^16.12.0",
		"graphql-request": "^7.4.0",
		"graphql-ws": "^6.0.6",
		"husky": "^9.1.7",
		"lint-staged": "^15.5.2",
		"npm-run-all": "^4.1.5",
		"prettier": "^3.7.4",
		"ts-loader": "^9.5.4",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.50.0",
		"url-pattern": "^1.0.3",
		"uuid": "^13.0.0",
		"webpack": "^5.104.0",
		"webpack-cli": "^6.0.1",
		"ws": "^8.18.3"
	},
	"lint-staged": {
		"src/sessions/graphql/sdk.ts": [],
		"*.{ts,js,mjs,cjs}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,md}": [
			"prettier --write"
		]
	}
}
