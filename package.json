		"menus": {
			"explorer/context": [
				{
					"command": "rewst-buddy.LinkFolder",
					"when": "rewst-buddy.anyActiveSessions && explorerResourceIsFolder && resourcePath not in rewst-buddy.linkedFolders"
				},
				{
					"command": "rewst-buddy.UnlinkFolder",
