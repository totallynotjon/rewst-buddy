{
	"publisher": "JBramley",
	"name": "rewst-buddy",
	"displayName": "rewst-buddy",
	"description": "Unofficial community VS Code extension for editing Rewst templates locally. Not affiliated with Rewst LLC.",
	"version": "0.43.5",
	"icon": "media/rewst-buddy.png",
	"engines": {
		"vscode": "^1.122.0"
	},
	"categories": [
		"Other"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/totallynotjon/rewst-buddy.git"
	},
	"bugs": {
		"url": "https://github.com/totallynotjon/rewst-buddy/issues"
	},
	"license": "MIT",
	"homepage": "https://github.com/totallynotjon/rewst-buddy/blob/main/README.md",
	"keywords": [
		"rewst",
		"Rewst",
		"buddy"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"languageModelChatProviders": [
			{
				"vendor": "rewst-buddy",
				"displayName": "Cage-Free Rewsty"
			}
		],
		"languageModelTools": [
			{
				"name": "list_template_links",
				"displayName": "List Template Links",
				"toolReferenceName": "rewstListTemplateLinks",
				"canBeReferencedInPrompt": true,
				"tags": [
					"rewst"
				],
				"modelDescription": "List local files linked to Rewst templates (path, template name, template id, org).",
				"inputSchema": {
					"type": "object",
					"properties": {}
				}
			},
			{
				"name": "web_search",
				"displayName": "Web Search",
				"toolReferenceName": "rewstWebSearch",
				"canBeReferencedInPrompt": true,
				"tags": [
					"rewst"
				],
				"modelDescription": "Search the public web; returns result titles, URLs, and snippets.",
				"inputSchema": {
					"type": "object",
					"properties": {
						"query": {
							"type": "string",
							"description": "Web search query."
						}
					},
					"required": [
						"query"
					]
				}
			},
			{
				"name": "rewst_graphql_schema",
				"displayName": "Inspect Rewst GraphQL Schema",
				"toolReferenceName": "rewstGraphqlSchema",
				"canBeReferencedInPrompt": true,
				"tags": [
					"rewst"
				],
				"modelDescription": "Inspect the Rewst GraphQL schema with the user session before composing operations. With no args, lists root Query/Mutation/Subscription fields. Use typeName to inspect fields/input fields/enum values for one type. Use search to find matching type names and root operation fields.",
				"inputSchema": {
					"type": "object",
					"properties": {
						"typeName": {
							"type": "string",
							"description": "Inspect one named GraphQL type."
						},
						"search": {
							"type": "string",
							"description": "Find matching type names and root operation fields."
						},
						"includeDeprecated": {
							"type": "boolean",
							"description": "Include deprecated fields/values."
						}
					}
				}
			},
			{
				"name": "rewst_approval",
				"displayName": "Approve Rewst Action",
				"toolReferenceName": "rewstApprove",
				"canBeReferencedInPrompt": true,
				"tags": [
					"rewst"
				],
				"modelDescription": "Internal: approves a Rewst-side action Cage-Free Rewsty paused for. Emitted by the Cage-Free Rewsty chat model itself — never request this tool.",
				"inputSchema": {
					"type": "object",
					"properties": {
						"toolNames": {
							"type": "array",
							"items": {
								"type": "string"
							},
							"description": "Rewst tool names awaiting approval."
						},
						"argsPreview": {
							"type": "string",
							"description": "Human-readable preview of the tool arguments."
						},
						"orgId": {
							"type": "string",
							"description": "Organization the approval applies to."
						},
						"resume": {
							"type": "string",
							"description": "The original request to re-send once approved."
						}
					},
					"required": [
						"toolNames",
						"orgId",
						"resume"
					]
				}
			},
			{
				"name": "rewst_graphql",
				"displayName": "Run Rewst GraphQL Operation",
				"toolReferenceName": "rewstGraphql",
				"canBeReferencedInPrompt": true,
				"tags": [
					"rewst"
				],
				"modelDescription": "Run a GraphQL operation against the user's Rewst instance with their session. Prefer rewst_graphql_schema first when you are unsure about field names or arguments. Queries run directly and return JSON data. Mutations require the user's approval and MUST include four identifying fields: scopeId and scopeName (the id and human-readable name of the single resource the mutation changes, e.g. a workflow's id and name) plus orgId and orgName (the id and name of the org it runs in). A mutation missing any of them is refused. Reuse the exact same scopeId and orgId for every change to that same object — approval is remembered per resource for the session, so approving one mutation lets later mutations to that same resource run without re-asking, while a different resource is confirmed separately. The names are shown to the user in the approval prompt so they can recognize what is changing; only the ids are used to remember approval. Subscriptions are not supported.",
				"inputSchema": {
					"type": "object",
					"properties": {
						"query": {
							"type": "string",
							"description": "GraphQL operation text."
						},
						"variables": {
							"type": "object",
							"description": "Operation variables."
						},
						"scopeId": {
							"type": "string",
							"description": "Required for mutations: a stable id of the resource being changed (e.g. the workflow id). Approval is remembered per resource for the session; reuse the same id for repeated edits to the same object."
						},
						"scopeName": {
							"type": "string",
							"description": "Required for mutations: the resource's human-readable name (e.g. the workflow name), shown to the user in the approval prompt."
						},
						"orgId": {
							"type": "string",
							"description": "Required for mutations: the id of the org the mutation runs in."
						},
						"orgName": {
							"type": "string",
							"description": "Required for mutations: the name of the org the mutation runs in, shown in the approval prompt."
						}
					},
					"required": [
						"query"
					]
				}
			}
		],
		"configuration": {
			"title": "Settings Editor Rewst-Buddy",
			"type": "object",
			"properties": {
				"rewst-buddy.regions": {
					"type": "array",
					"default": [
						{
							"name": "North America",
							"cookieName": "appSession",
							"graphqlUrl": "https://api.rewst.io/graphql",
							"loginUrl": "https://app.rewst.io"
						}
					],
					"description": "Regional configuration for different Rewst instances",
					"items": {
						"type": "object",
						"properties": {
							"name": {
								"type": "string",
								"description": "Display name for the region"
							},
							"cookieName": {
								"type": "string",
								"description": "Session cookie name for authentication"
							},
							"graphqlUrl": {
								"type": "string",
								"description": "GraphQL API endpoint URL"
							},
							"loginUrl": {
								"type": "string",
								"description": "Login page URL for the region"
							},
							"subscriptionsUrl": {
								"type": "string",
								"description": "GraphQL subscriptions WebSocket URL (optional; derived from graphqlUrl when omitted)"
							}
						},
						"required": [
							"name",
							"cookieName",
							"graphqlUrl",
							"loginUrl"
						]
					}
				},
				"rewst-buddy.syncOnSaveByDefault": {
					"type": "boolean",
					"default": false,
					"description": "When enabled, all linked files sync on save by default (use Disable Sync-On-Save to exclude specific files). When disabled, files only sync when explicitly enabled."
				},
				"rewst-buddy.autoFetchOnOpen": {
					"type": "boolean",
					"default": true,
					"description": "When enabled, automatically fetch remote template updates when opening linked files. This only applies changes if the local file hasn't been modified since the last sync."
				},
				"rewst-buddy.server.enabled": {
					"type": "boolean",
					"default": true,
					"description": "Enable the local HTTP server to receive session tokens from browser extensions"
				},
				"rewst-buddy.server.port": {
					"type": "number",
					"default": 27121,
					"minimum": 1024,
					"maximum": 65535,
					"description": "Port number for the local HTTP server (default: 27121)"
				},
				"rewst-buddy.server.host": {
					"type": "string",
					"default": "127.0.0.1",
					"description": "Host address to bind the server (default: 127.0.0.1 for localhost-only access)"
				},
				"rewst-buddy.ai.conversationType": {
					"type": "string",
					"enum": [
						"HELP_DOCS",
						"WORKFLOW_DIAGNOSIS"
					],
					"default": "HELP_DOCS",
					"description": "Conversation type sent to the Rewst AI assistant (HELP_DOCS answers documentation questions)"
				},
				"rewst-buddy.ai.customInstructions": {
					"type": "string",
					"default": "",
					"editPresentation": "multilineText",
					"description": "Standing instructions prepended to every message sent to the Rewst AI assistant (e.g. preferred answer style, your environment details). Note: this is sent as part of your message — it cannot override Rewst's own system prompt."
				},
				"rewst-buddy.ai.showActivity": {
					"type": "boolean",
					"default": true,
					"description": "Show Cage-Free Rewsty's live activity (documentation searches and tool calls) as it works, instead of only a spinner until the answer arrives."
				},
				"rewst-buddy.ai.enableWorkspaceTools": {
					"type": "boolean",
					"default": true,
					"description": "Let Cage-Free Rewsty see a compact workspace overview (folder names and top-level entries) and the list of files linked to Rewst templates. This context is sent to the Rewst AI assistant — disable if you don't want workspace structure shared. File reading, editing, search, and terminal access come from VS Code's built-in agent-mode tools, not from this extension."
				},
				"rewst-buddy.ai.enableWebTools": {
					"type": "boolean",
					"default": false,
					"description": "Let Cage-Free Rewsty search the public web. The assistant chooses what to search, so enabling this allows it to direct network requests from your machine (private/loopback hosts are always blocked). Opening result pages uses VS Code's built-in fetch tool."
				},
				"rewst-buddy.ai.maxToolRounds": {
					"type": "number",
					"default": 4,
					"minimum": 0,
					"description": "Legacy — no effect since Cage-Free Rewsty became a chat model: VS Code's chat runs the tool loop and owns its limits. Kept so existing settings files don't warn."
				},
				"rewst-buddy.ai.enableGraphqlTool": {
					"type": "boolean",
					"default": false,
					"description": "Let Cage-Free Rewsty compose and run GraphQL operations against your Rewst instance using your session. Queries run directly; mutations always require your approval through VS Code's inline chat confirmation (Continue / Cancel) showing the full operation, must declare the resource and org they change (scopeId, scopeName, orgId, orgName), and approval is remembered for the session by the ids. Off by default because the session can read and change anything you can in Rewst."
				}
			}
		},
