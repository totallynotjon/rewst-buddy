# Local test secrets — copy this file to `.env` and fill in the value.
# `.env` is gitignored; this template is committed.
#
# Used by integration tests (`npm run test:integration`). The token is your
# Rewst session cookie/token. A production-capable token may be used only because
# every integration operation is hard-scoped to REWST_TEST_ORG_ID below.
# Loaded by `.vscode-test.mjs`; an exported env var of the same name wins.

REWST_TEST_TOKEN=

# The only org integration tests may query or mutate. Defaults to Jon's sandbox
# when omitted. Other contributors should set this to their own sandbox org id.
# Tests fail closed when the token does not manage this org; they never fall back
# to the token's primary/production organization.
REWST_TEST_ORG_ID=01940973-8a88-7109-8ba7-d64bfbb18950
